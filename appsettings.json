{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.AspNetCore.Authentication": "Error",
        "Microsoft.Extensions.Http": "Information",
        "System.Net.Http.HttpClient": "Warning",
        "CasCap.Services.MetadataBgService": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "AppConfig": {
    "KeyVaultName": "my-keyvault",
    "OtlpExporterEndpoint": "http://opentelemetry-collector.monitoring.svc:4317",
    "AzureEntraTenantId": "00000000-0000-0000-0000-000000000000",
    "AzureEntraPfxPath": "/etc/certs/edge-sp-cert",
    "SwaggerEndpoints": {
      "KNX": "/api/v1/knx/swagger/v1.json",
      "Buderus": "/api/v1/buderus/swagger/v1.json",
      "Fronius": "/api/v1/fronius/swagger/v1.json",
      "DoorBird": "/api/v1/doorbird/swagger/v1.json"
    }
  },
  "CasCap": {
    "AuditConfig": {
      "Enabled": true,
      "RedisStreamKey": "audit:mcp:calls",
      "MaxStreamLength": 10000,
      "ApprovalEnabled": true,
      "ApprovalTimeoutMs": 60000,
      "AlwaysRequireApproval": [],
      "NeverRequireApproval": []
    },
    "CachingConfig": {
      "RemoteCacheConnectionString": "redis-master.data.svc:6379,allowAdmin=true,abortConnect=false,connectTimeout=1000",
      "DistributedLockingEnabled": true,
      "RemoteCache": {
        "SerializationType": "Json"
      },
      "MemoryCacheSizeLimit": 100,
      "Redlock": {
        "RedisKeyFormat": "lock:{0}",
        "ExpiryMs": 5000,
        "WaitMs": 5000,
        "RetryMs": 250,
        "Profiles": {
          "LeaderElection": {
            "ExpiryMs": 30000,
            "WaitMs": 60000,
            "RetryMs": 5000
          }
        }
      }
    },
    "AIConfig": {
      "Providers": {
        "EdgeGpu": {
          "Type": "Ollama",
          "Endpoint": "http://ollama-gpu.utilities.svc:11434",
          "ModelName": "qwen3.5:9b",
          "ReasoningEffort": "None"
        },
        "OpenAI": {
          "Type": "OpenAI",
          "ModelName": "gpt-5-mini",
          "ReasoningEffort": "Low",
          "ApiKey": "SET_VIA_ENV_OR_KEYVAULT"
        },
        "AzureOpenAI": {
          "Type": "AzureOpenAI",
          "Endpoint": "https://myopenai.openai.azure.com/",
          "ModelName": "gpt-4o-mini",
          "ReasoningEffort": "Low"
        },
        "EdgeCpuWhisper": {
          "Type": "Ollama",
          "Endpoint": "http://ollama-gpu.utilities.svc:11434",
          "ModelName": "karanchopda333/whisper"
        }
      },
      "PollTtlMs": 3600000,
      "SessionTtlDays": 7,
      "Agents": {
        "SecurityAgent": {
          "Name": "Security Agent",
          "Provider": "EdgeGpu",
          "MaxMessages": 10,
          "InstructionsSource": "CasCap.Resources.SecurityAgent.instructions.md",
          "Description": "Specialist agent for security cameras, the front door entry system, and the front door light. Delegate to this agent for doorbell events, door camera images (live and history), front door state queries, video stream URL, and turning the front door light on or off. Can present choices to the user via polls.",
          "Prompt": "This is a photo taken by a door entry system triggered on motion, from a security perspective describe concisely who/what is in the frame.",
          "Tools": [
            {
              "Service": "SystemMcpQueryService"
            },
            {
              "Service": "FrontDoorMcpQueryService"
            },
            {
              "Service": "BusSystemMcpQueryService",
              "IncludeTools": [
                "get_house_front_door_state"
              ]
            },
            {
              "Service": "SmartLightingMcpQueryService",
              "IncludeTools": [
                "turn_on_house_door_light",
                "turn_off_house_door_light"
              ]
            },
            {
              "Service": "MessagingMcpQueryService"
            }
          ],
          "Settings": {
            "ImageCacheKeyPrefix": "doorbird:image",
            "ImageCacheTtlMs": 300000
          }
        },
        "HeatingAgent": {
          "Name": "Heating Agent",
          "Provider": "OpenAI",
          "InstructionsSource": "CasCap.Resources.HeatingAgent.instructions.md",
          "Description": "Specialist agent for the heat pump system and KNX heating zones — monitoring state, temperatures, setpoints, and adjusting data points. Delegate to this agent for heat pump status, DHW temperature, KNX zone temperatures/setpoints, or heating control operations. Can present choices to the user via polls.",
          "Prompt": "What is the current heat pump status?",
          "Tools": [
            {
              "Service": "SystemMcpQueryService"
            },
            {
              "Service": "HeatPumpMcpQueryService"
            },
            {
              "Endpoint": "https://api.example.com/mcp/knx",
              "IncludeTools": [
                "change_house_heating_zone",
                "get_house_heating_zones",
                "get_house_heating_zone"
              ]
            },
            {
              "Service": "MessagingMcpQueryService"
            }
          ],
          "Settings": {}
        },
        "EnergyAgent": {
          "Name": "Energy Agent",
          "Provider": "AzureOpenAI",
          "InstructionsSource": "CasCap.Resources.EnergyAgent.instructions.md",
          "Description": "Specialist agent for the solar inverter, battery storage, and household power consumption — power flow, electrical readings, and connected device status. Delegate to this agent for solar production, battery charge level, grid import/export, or energy consumption queries. Can present choices to the user via polls.",
          "Prompt": "What is the current solar production and battery level?",
          "Tools": [
            {
              "Service": "SystemMcpQueryService"
            },
            {
              "Service": "InverterMcpQueryService"
            },
            {
              "Service": "MessagingMcpQueryService"
            }
          ]
        },
        "HomeControlAgent": {
          "Name": "Home Control Agent",
          "Provider": "EdgeGpu",
          "InstructionsSource": "CasCap.Resources.HomeControlAgent.instructions.md",
          "Description": "Specialist agent for home control — lighting (KNX ceiling/wall and WiZ smart bulbs: on/off, status, all-on/all-off), shutters (list all with current status, query individual position/slats/direction, open/close, set position — KNX convention: 0=fully open, 100=fully closed), power outlets (list status, switch on/off), room/floor structure queries, and KNX bus diagnostics (group address search, connectivity testing). Delegate to this agent for light or shutter status queries, light or shutter control, room queries, or bus-level diagnostics. Can present choices to the user via polls.",
          "Prompt": "How many lights are switched on?",
          "Tools": [
            {
              "Service": "SystemMcpQueryService",
              "ExcludeTools": [
                "get_providers",
                "get_agents"
              ]
            },
            {
              "Service": "BusSystemMcpQueryService",
              "ExcludeTools": [
                "change_house_heating_zone",
                "get_house_heating_zones",
                "get_house_heating_zone"
              ]
            },
            {
              "Service": "SmartLightingMcpQueryService"
            },
            {
              "Service": "MessagingMcpQueryService"
            }
          ]
        },
        "CommsAgent": {
          "Name": "Comms Agent",
          "Provider": "EdgeGpu",
          "MaxMessages": 30,
          "InstructionsSource": "CasCap.Resources.CommsAgent.instructions.md",
          "Description": "Top-level orchestrator for incoming user messages. Delegates to specialist sub-agents: SecurityAgent (door cameras, entry system, door light), HeatingAgent (heat pump and KNX heating zone monitoring/control), EnergyAgent (solar inverter, battery, power consumption), HomeControlAgent (KNX lighting, shutters — including listing current status/positions and control, outlets, room queries, bus diagnostics), InfraAgent (edge hardware GPU/CPU monitoring), AppliancesAgent (Home Connect kitchen/laundry appliances), AudioAgent (audio transcription via Whisper). Also has direct access to KNX room/floor queries.",
          "Prompt": "How can I help you with your smart home?",
          "Tools": [
            {
              "Service": "SystemMcpQueryService"
            },
            {
              "Service": "BusSystemMcpQueryService",
              "IncludeTools": [
                "get_house_rooms",
                "get_house_floors"
              ]
            },
            {
              "Service": "MessagingMcpQueryService"
            },
            {
              "Agent": "SecurityAgent"
            },
            {
              "Agent": "HeatingAgent"
            },
            {
              "Agent": "EnergyAgent"
            },
            {
              "Agent": "InfraAgent"
            },
            {
              "Agent": "HomeControlAgent"
            },
            {
              "Agent": "AppliancesAgent"
            },
            {
              "Agent": "AudioAgent"
            }
          ],
          "Settings": {
            "GroupName": "SmartHaus",
            "ProfileName": "Smart Haus"
          }
        },
        "InfraAgent": {
          "Name": "Infra Agent",
          "Provider": "EdgeGpu",
          "InstructionsSource": "CasCap.Resources.InfraAgent.instructions.md",
          "Description": "Specialist agent for edge hardware infrastructure monitoring — GPU temperature, utilisation, power draw, and node health. Delegate to this agent for questions about compute node status, GPU metrics, or hardware health. Can present choices to the user via polls.",
          "Prompt": "What is the current status of the edge hardware?",
          "Tools": [
            {
              "Service": "SystemMcpQueryService"
            },
            {
              "Service": "EdgeHardwareMcpQueryService"
            },
            {
              "Service": "MessagingMcpQueryService"
            }
          ]
        },
        "AudioAgent": {
          "Name": "Audio Agent",
          "Provider": "EdgeCpuWhisper",
          "MaxMessages": 1,
          "InstructionsSource": "CasCap.Resources.AudioAgent.instructions.md",
          "Description": "Audio transcription agent using a Whisper model. Used internally by CommsAgent to transcribe audio attachments before processing.",
          "Prompt": "Transcribe the following audio clip.",
          "Tools": []
        },
        "AppliancesAgent": {
          "Enabled": false,
          "Name": "Appliances Agent",
          "Provider": "EdgeGpu",
          "InstructionsSource": "CasCap.Resources.AppliancesAgent.instructions.md",
          "Description": "Specialist agent for Home Connect kitchen and laundry appliances — dishwasher, oven, washing machine, dryer. Delegate to this agent for checking appliance status, starting programs, or executing appliance actions. Can present choices to the user via polls. Currently disabled pending tooling readiness.",
          "Prompt": "What appliances are connected?",
          "Tools": [
            {
              "Service": "SystemMcpQueryService"
            },
            {
              "Service": "AppliancesMcpQueryService"
            },
            {
              "Service": "MessagingMcpQueryService"
            }
          ]
        }
      }
    },
