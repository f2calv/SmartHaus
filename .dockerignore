# first ignore everything
**

# explictly add exceptions for required files/paths
!src/**/*.cs
!**/*.csproj
!**/appsettings.*
!global.json
!**/*.props
!**/*.targets

# custom
!**/*.lua
!**/*.instructions.md
!wait-for-it.sh
!ffmpeg-record.sh

# Debug builds (Dockerfile.Debug) sync the local sibling repos into deps/.
# Include their full source tree so project references resolve.
!deps/**

# never leak local-only secrets or build artefacts into the image
**/appsettings.Local*.json
deps/**/bin
deps/**/obj
deps/**/.git
deps/**/.vs
